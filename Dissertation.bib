@misc{wu_PIMamba_2026,
  title = {{{PI-Mamba}}: {{Linear-Time Protein Backbone Generation}} via {{Spectrally Initialized Flow Matching}}},
  shorttitle = {{{PI-Mamba}}},
  author = {Wu, Tianyu and Zhu, Lin},
  year = 2026,
  month = mar,
  journal = {arXiv.org},
  urldate = {2026-04-06},
  abstract = {Motivation: Generative models for protein backbone design have to simultaneously ensure geometric validity, sampling efficiency, and scalability to long sequences. However, most existing approaches rely on iterative refinement, quadratic attention mechanisms, or post-hoc geometry correction, leading to a persistent trade-off between computational efficiency and structural fidelity. Results: We present Physics-Informed Mamba (PI-Mamba), a generative model that enforces exact local covalent geometry by construction while enabling linear-time inference. PI-Mamba integrates a differentiable constraint-enforcement operator into a flow-matching framework and couples it with a Mamba-based state-space architecture. To improve optimisation stability and backbone realism, we introduce a spectral initialization derived from the Rouse polymer model and an auxiliary cis-proline awareness head. Across benchmark tasks, PI-Mamba achieves 0.0\textbackslash\% local geometry violations and high designability (scTM = \$0.91\textbackslash pm 0.03\$, n = 100), while scaling to proteins exceeding 2,000 residues on a single A5000 GPU (24 GB).},
  howpublished = {https://arxiv.org/abs/2603.26705v1},
  langid = {english},
  file = {/Users/research/Zotero/storage/WTEYFU46/Wu and Zhu - 2026 - PI-Mamba Linear-Time Protein Backbone Generation via Spectrally Initialized Flow Matching.pdf}
}

