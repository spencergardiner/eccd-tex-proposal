@misc{gloy_HollowFlow_2025,
  title = {{{HollowFlow}}: {{Efficient Sample Likelihood Evaluation}} Using {{Hollow Message Passing}}},
  shorttitle = {{{HollowFlow}}},
  author = {Gloy, Johann Flemming and Olsson, Simon},
  year = 2025,
  month = oct,
  number = {arXiv:2510.21542},
  eprint = {2510.21542},
  primaryclass = {stat},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2510.21542},
  urldate = {2026-04-13},
  abstract = {Flow and diffusion-based models have emerged as powerful tools for scientific applications, particularly for sampling non-normalized probability distributions, as exemplified by Boltzmann Generators (BGs). A critical challenge in deploying these models is their reliance on sample likelihood computations, which scale prohibitively with system size \$n\$, often rendering them infeasible for large-scale problems. To address this, we introduce \$\textbackslash textit\textbraceleft HollowFlow\textbraceright\$, a flow-based generative model leveraging a novel non-backtracking graph neural network (NoBGNN). By enforcing a block-diagonal Jacobian structure, HollowFlow likelihoods are evaluated with a constant number of backward passes in \$n\$, yielding speed-ups of up to \$\textbackslash mathcal\textbraceleft O\textbraceright (n\textasciicircum 2)\$: a significant step towards scaling BGs to larger systems. Crucially, our framework generalizes: \$\textbackslash textbf\textbraceleft any equivariant GNN or attention-based architecture\textbraceright\$ can be adapted into a NoBGNN. We validate HollowFlow by training BGs on two different systems of increasing size. For both systems, the sampling and likelihood evaluation time decreases dramatically, following our theoretical scaling laws. For the larger system we obtain a \$10\textasciicircum 2\textbackslash times\$ speed-up, clearly illustrating the potential of HollowFlow-based approaches for high-dimensional scientific problems previously hindered by computational bottlenecks.},
  archiveprefix = {arXiv},
  keywords = {Computer Science - Machine Learning,Statistics - Machine Learning},
  file = {/Users/research/Zotero/storage/J33KQATI/Gloy and Olsson - 2025 - HollowFlow Efficient Sample Likelihood Evaluation using Hollow Message Passing.pdf;/Users/research/Zotero/storage/ND9Y596U/2510.html}
}

