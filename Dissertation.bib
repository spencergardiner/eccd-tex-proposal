@article{alfano_Molecular_2024,
  title = {Molecular {{Crowding}}: {{The History}} and {{Development}} of a {{Scientific Paradigm}}},
  shorttitle = {Molecular {{Crowding}}},
  author = {Alfano, Caterina and Fichou, Yann and Huber, Klaus and Weiss, Matthias and Spruijt, Evan and Ebbinghaus, Simon and De Luca, Giuseppe and Morando, Maria Agnese and Vetri, Valeria and Temussi, Piero Andrea and Pastore, Annalisa},
  year = 2024,
  month = mar,
  journal = {Chemical Reviews},
  volume = {124},
  number = {6},
  pages = {3186--3219},
  publisher = {American Chemical Society},
  issn = {0009-2665},
  doi = {10.1021/acs.chemrev.3c00615},
  urldate = {2026-04-10},
  abstract = {It is now generally accepted that macromolecules do not act in isolation but ``live'' in a crowded environment, that is, an environment populated by numerous different molecules. The field of molecular crowding has its origins in the far 80s but became accepted only by the end of the 90s. In the present issue, we discuss various aspects that are influenced by crowding and need to consider its effects. This Review is meant as an introduction to the theme and an analysis of the evolution of the crowding concept through time from colloidal and polymer physics to a more biological perspective. We introduce themes that will be more thoroughly treated in other Reviews of the present issue. In our intentions, each Review may stand by itself, but the complete collection has the aspiration to provide different but complementary perspectives to propose a more holistic view of molecular crowding.},
  file = {/Users/research/Zotero/storage/98G4WHLL/Alfano et al. - 2024 - Molecular Crowding The History and Development of a Scientific Paradigm.pdf}
}

